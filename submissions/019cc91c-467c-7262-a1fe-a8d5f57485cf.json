{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_ANTHROPIC_API_KEY": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_ANTHROPIC_MODEL": {
        "type": "string"
      },
      "officeqa_agent_LLM_PROVIDER": {
        "type": "string"
      },
      "officeqa_agent_OPENAI_API_KEY": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_OPENAI_MODEL": {
        "type": "string"
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/main/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/alphadl/agentx-agentbeats-officeqa/main/amber-manifest.json5",
      "config": {
        "ANTHROPIC_API_KEY": "${config.officeqa_agent_ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "${config.officeqa_agent_ANTHROPIC_MODEL}",
        "LLM_PROVIDER": "${config.officeqa_agent_LLM_PROVIDER}",
        "OPENAI_API_KEY": "${config.officeqa_agent_OPENAI_API_KEY}",
        "OPENAI_MODEL": "${config.officeqa_agent_OPENAI_MODEL}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019cc90e-a19b-7663-974d-fa0fe84d2b92"
    }
  }
}