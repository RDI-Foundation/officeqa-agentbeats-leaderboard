{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_json_output": {
        "type": "boolean",
        "default": false
      },
      "officeqa_agent_model_name": {
        "type": "string",
        "default": "z-ai/glm-5"
      },
      "officeqa_agent_openrouter_api_key": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_openrouter_base_url": {
        "type": "string",
        "default": "https://openrouter.ai/api/v1"
      },
      "officeqa_agent_reasoning_enabled": {
        "type": "boolean",
        "default": true
      },
      "officeqa_agent_retrieval_enabled": {
        "type": "boolean",
        "default": false
      },
      "officeqa_agent_tavily_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "officeqa_agent_tools_enabled": {
        "type": "boolean",
        "default": false
      }
    },
    "required": [
      "officeqa_agent_openrouter_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "max_concurrent": 10,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/soumya-batra/agentswe-general/refs/heads/main/amber-manifest.json5",
      "config": {
        "json_output": "${config.officeqa_agent_json_output}",
        "model_name": "${config.officeqa_agent_model_name}",
        "openrouter_api_key": "${config.officeqa_agent_openrouter_api_key}",
        "openrouter_base_url": "${config.officeqa_agent_openrouter_base_url}",
        "reasoning_enabled": "${config.officeqa_agent_reasoning_enabled}",
        "retrieval_enabled": "${config.officeqa_agent_retrieval_enabled}",
        "tavily_api_key": "${config.officeqa_agent_tavily_api_key}",
        "tools_enabled": "${config.officeqa_agent_tools_enabled}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019e5cac-4e2a-7740-8e49-c234f149fe42"
    }
  }
}