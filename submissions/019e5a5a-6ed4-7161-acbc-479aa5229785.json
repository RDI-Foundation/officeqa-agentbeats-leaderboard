{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_gemini_api_key": {
        "type": "string",
        "secret": true,
        "description": "Gemini API key used only as fallback."
      },
      "officeqa_agent_gemini_model": {
        "type": "string",
        "description": "Gemini fallback model."
      },
      "officeqa_agent_local_llm_api_key": {
        "type": "string",
        "secret": true,
        "description": "Bearer token for the secure local LLM proxy."
      },
      "officeqa_agent_public_local_llm_base_url": {
        "type": "string",
        "description": "Public OpenAI-compatible local cluster model endpoint, ending with /v1."
      },
      "officeqa_agent_public_local_llm_model": {
        "type": "string",
        "description": "Model name served by the public local endpoint."
      }
    },
    "required": [
      "officeqa_agent_public_local_llm_base_url",
      "officeqa_agent_public_local_llm_model",
      "officeqa_agent_local_llm_api_key",
      "officeqa_agent_gemini_api_key",
      "officeqa_agent_gemini_model"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "max_concurrent": 10,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/Kingmaoqin/DHAI_AgenticAI/main/amber-manifest.json5",
      "config": {
        "gemini_api_key": "${config.officeqa_agent_gemini_api_key}",
        "gemini_model": "${config.officeqa_agent_gemini_model}",
        "local_llm_api_key": "${config.officeqa_agent_local_llm_api_key}",
        "public_local_llm_base_url": "${config.officeqa_agent_public_local_llm_base_url}",
        "public_local_llm_model": "${config.officeqa_agent_public_local_llm_model}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    },
    {
      "to": "#officeqa_agent.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019e52c3-7764-76b1-bfcb-a0c3d584d964"
    }
  }
}